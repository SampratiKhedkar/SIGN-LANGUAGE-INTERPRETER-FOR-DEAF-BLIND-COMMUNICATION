<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_feelspeak_offwhite">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBarSettings"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="#682B2B"
            android:paddingTop="30dp"
            android:paddingBottom="10dp"
            android:minHeight="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@android:color/white">

            <TextView
                android:id="@+id/toolbarTitleSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/feelspeak_cursive"
                android:text="Settings"
                android:textColor="@android:color/white"
                android:textSize="32sp" />
        </com.google.android.material.appbar.MaterialToolbar>


        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- User Type Selection Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select User Type"
                    android:textSize="22sp"
                    android:textStyle="italic|bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="40dp"
                    android:layout_marginTop="60dp"/>

                <RadioGroup
                    android:id="@+id/radio_group_user_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">

                    <RadioButton
                        android:id="@+id/radio_normal"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="12dp"
                        android:text="Normal Person"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@drawable/btn_red_gradient"
                        app:backgroundTint="@null" />

                    <RadioButton
                        android:id="@+id/radio_deaf"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="12dp"
                        android:text="Deaf Person"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@drawable/btn_orange_gradient"
                        app:backgroundTint="@null" />

                    <RadioButton
                        android:id="@+id/radio_blind"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="12dp"
                        android:text="Blind Person"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@drawable/btn_yellow_gradient"
                        app:backgroundTint="@null" />

                </RadioGroup>

                <Button
                    android:id="@+id/button_save_user_type"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Save User Type"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="50dp" />

                <!-- Divider Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#000000"
                    android:layout_marginBottom="24dp" />

                <!-- Account Settings Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Account Settings"
                    android:textSize="22sp"
                    android:textStyle="italic|bold"
                    android:textColor="#000000"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="30dp" />

                <Button
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Change Password"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:background="@drawable/btn_red_gradient"
                    android:layout_marginBottom="45dp" />

                <!-- Divider Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#000000"
                    android:layout_marginBottom="24dp" />

                <!-- Danger Zone Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Delete Account"
                    android:textSize="22sp"
                    android:textStyle="italic|bold"
                    android:textColor="#000000"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="30dp"/>

                <Button
                    android:id="@+id/btnDeleteAccount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Delete Account"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:background="@drawable/btn_red_gradient"
                    android:layout_marginBottom="20dp" />

                <!-- Warning Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Deleting your account will permanently remove all your data including profile information, photos, and settings. This action cannot be undone."
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>