<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_feelspeak_offwhite">

    <!-- Toolbar + content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBarUserType"
            style="@style/Widget.MaterialComponents.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:minHeight="?attr/actionBarSize"
            android:background="#682B2B"
            android:paddingTop="30dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/toolbarTitleUserType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/feelspeak_cursive"
                android:text="User Type"
                android:textColor="@android:color/white"
                android:textSize="32sp" />
        </com.google.android.material.appbar.MaterialToolbar>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_feelspeak_offwhite"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Select User Type"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="48dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBlind"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="👁️ Blind Person"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="@drawable/btn_red_gradient"
                app:backgroundTint="@null"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNormal"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="🙋 Normal Person"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="@drawable/btn_orange_gradient"
                app:backgroundTint="@null"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeaf"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="🧏 Deaf Person"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:background="@drawable/btn_yellow_gradient"
                app:backgroundTint="@null"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>